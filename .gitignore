# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.translation

# Import cache (regenerated by Godot)
.import/

# Mono/C# specific (if ever used)
.mono/
data_*/
mono_crash.*.json

# Local dev notes — references, inspiration, design scratch
_dev/

# AI tool configs — local only
CLAUDE.md
GEMINI.md
.claude/

# OS generated
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo

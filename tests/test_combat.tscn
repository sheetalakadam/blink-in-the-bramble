[gd_scene load_steps=3 format=3]

[ext_resource type="PackedScene" path="res://scenes/ui/MomentumSpine.tscn" id="1_spine"]

[sub_resource type="GDScript" id="GDScript_1"]
script/source = "extends Node2D

func _ready() -> void:
	print(\"[TEST_COMBAT] Initializing test combat...\")
	
	var participants = [
		{\"name\": \"Zi\", \"speed\": 15},
		{\"name\": \"Suri\", \"speed\": 12},
		{\"name\": \"Scavenger\", \"speed\": 10}
	]
	
	CombatManager.turn_started.connect(_on_turn_started)
	CombatManager.start_combat(participants)

func _on_turn_started(entity: Dictionary) -> void:
	print(\"[TEST_COMBAT] It is now \", entity[\"name\"], \"'s turn.\")
	
	# Simulate some momentum gain
	MomentumSystem.add_momentum(20.0)
	
	# Wait a bit then advance
	await get_tree().create_timer(1.0).timeout
	
	if MomentumSystem.current_momentum >= 100.0:
		print(\"[TEST_COMBAT] Maximum Surge reached. Resetting for test loop.\")
		MomentumSystem.reset()
		
	CombatManager.advance_turn()
"

[node name="TestCombat" type="Node2D"]
script = SubResource("GDScript_1")

[node name="MomentumSpine" parent="." instance=ExtResource("1_spine")]
offset_right = 60.0
